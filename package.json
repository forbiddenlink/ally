{
  "name": "ally",
  "version": "1.0.0",
  "description": "Your codebase's accessibility ally. Scans, explains, and fixes a11y issues using GitHub Copilot CLI.",
  "type": "module",
  "bin": {
    "ally": "./dist/cli.js"
  },
  "files": [
    "dist",
    "mcp-server/dist",
    "README.md",
    "LICENSE",
    "ACCESSIBILITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build && cd mcp-server && npm run build",
    "dev": "tsc -w",
    "start": "node dist/cli.js",
    "test": "node --test --import tsx test/*.test.ts",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --import tsx test/*.test.ts",
    "test:coverage:check": "c8 check-coverage --lines 70 --functions 70 --branches 60",
    "test:e2e": "node --test --import tsx test/e2e/*.test.ts",
    "lint": "tsc --noEmit",
    "benchmark": "tsx benchmark/scan-speed.ts",
    "benchmark:ci": "tsx benchmark/scan-speed.ts --json --threshold 20",
    "prepublishOnly": "npm run build:all",
    "postinstall": "node -e \"console.log('\\n✅ ally-a11y installed! Run \\x1b[36mally init\\x1b[0m to get started.\\n')\"",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write"
  },
  "c8": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "test/**",
      "dist/**",
      "mcp-server/**"
    ],
    "all": true,
    "instrument": true,
    "sourceMap": true,
    "produce-source-map": true,
    "per-file": false,
    "skip-full": false,
    "report-dir": "./coverage",
    "temp-dir": "./coverage/tmp"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "axe-core",
    "cli",
    "github-copilot",
    "mcp",
    "copilot-cli"
  ],
  "author": "Liz Fong-Jones",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forbiddenlink/ally.git"
  },
  "homepage": "https://github.com/forbiddenlink/ally#readme",
  "bugs": {
    "url": "https://github.com/forbiddenlink/ally/issues"
  },
  "dependencies": {
    "@axe-core/puppeteer": "^4.11.3",
    "@clack/prompts": "^1.5.1",
    "@oclif/core": "^4.11.4",
    "@oclif/plugin-help": "^6.2.50",
    "@octokit/rest": "^22.0.1",
    "axe-core": "^4.12.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-progress": "^3.12.0",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "inquirer": "^9.2.23",
    "ora": "^8.1.1",
    "pa11y": "^9.1.1",
    "puppeteer": "^24.43.1",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.19.20",
    "@types/pa11y": "^5.3.7",
    "c8": "^10.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": ">=6.0.1",
      "simple-git": ">=3.32.3",
      "@hono/node-server": ">=1.19.10",
      "express-rate-limit": ">=8.2.2",
      "hono": ">=4.12.4",
      "minimatch": ">=10.2.3",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "rollup": ">=4.59.0"
    }
  }
}
